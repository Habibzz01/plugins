{
  "api_url": "https://api.hadits.site/v1/hadits/muslim/1",
  "ui": {
    "appBarTitle": "Mutiara Hadits",
    "bgColor": "#FDF6EC",
    "titleColor": "#5D4037",
    "elements": [
      {
        "type": "image",
        "url": "https://images.unsplash.com/photo-1542810634-71277d95dcbb?q=80&w=1000&auto=format&fit=crop",
        "height": 200,
        "radius": 20
      },
      { "type": "space", "height": -30 },
      {
        "type": "card",
        "bgColor": "#FFFFFF",
        "radius": 30,
        "elevation": 5,
        "children": [
          { "type": "text", "value": "HADITS HARI INI", "align": "center", "size": 12, "bold": true, "color": "#A1887F" },
          { "type": "space", "height": 20 },
          { "type": "text", "value": "{contents}", "align": "center", "size": 16, "italic": true, "color": "#3E2723" },
          { "type": "space", "height": 20 },
          { "type": "divider" },
          {
            "type": "row",
            "mainAlign": "center",
            "children": [
              { "type": "icon", "icon_name": "person", "color": "#D7CCC8", "size": 16 },
              { "type": "space", "width": 8 },
              { "type": "text", "value": "H.R. Muslim - No. {number}", "size": 12, "bold": true, "color": "#8D6E63" }
            ]
          }
        ]
      },
      { "type": "space", "height": 24 },
      {
        "type": "button",
        "label": "BAGIKAN KEBAIKAN",
        "bgColor": "#8D6E63",
        "textColor": "#FFFFFF",
        "radius": 15,
        "action_msg": "Hadits berhasil disalin ke clipboard!"
      }
    ]
  }
}
